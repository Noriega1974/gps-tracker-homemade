# Configuración de Entorno para GPS Tracker Gateway
# Copiar este archivo como .env y completar con los valores reales.

# Servidor Web
PORT=8080

# Ingesta de Datos (UDP)
UDP_PORT=5005

# Base de Datos (Amazon RDS PostgreSQL)
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=gps_db
DB_PORT=5432

# Nota: El archivo .env real NO debe subirse al repositorio Git por motivos de seguridad.

# Carga Manual de Datos (OBD-II CSV)
UPLOAD_PASSWORD=contraseña_de_la_empresa
INSTANCE_NAME=GPS-DEV-JOSE
